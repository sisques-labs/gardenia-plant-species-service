# Runtime
NODE_ENV=development
PORT=3000

# CORS — allowed browser origins (comma-separated).
# Falls back to FRONTEND_URL when unset. Required in production.
# CORS_ORIGINS=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# PostgreSQL — individual connection vars (DATABASE_URL is NOT supported)
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5436
DATABASE_USERNAME=gardenia
DATABASE_PASSWORD=secret
DATABASE_DATABASE=gardenia_plant_species
DATABASE_SYNCHRONIZE=false
DATABASE_MIGRATIONS_RUN=true

# Redis — ingest queue the worker (gardenia-plant-species-worker) drains.
# REDIS_QUEUE MUST match the worker's QUEUE_NAME.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_QUEUE=plant-species